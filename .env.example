# =====================================================================
# Steward configuration — copy to .env and edit. NEVER commit .env.
# Every value here is a safe placeholder. No real secrets, hosts, or IDs.
# =====================================================================

# ---- App ----
STEWARD_HOST=0.0.0.0
STEWARD_PORT=8080
STEWARD_LOG_LEVEL=INFO
# SQLite path. Use a path on a persistent volume in production.
STEWARD_DB_PATH=./data/steward.db

# ---- Proxmox client ----
# "mock" runs the in-memory simulator (default, safe, no real infra).
# "real" uses proxmoxer against a live cluster — DO NOT enable without intent.
STEWARD_PROXMOX_MODE=mock

# Only used when STEWARD_PROXMOX_MODE=real:
STEWARD_PROXMOX_HOST=proxmox.example.local
STEWARD_PROXMOX_PORT=8006
STEWARD_PROXMOX_USER=monitor@pve
# Prefer API tokens over passwords. Leave blank in the repo.
STEWARD_PROXMOX_TOKEN_NAME=
STEWARD_PROXMOX_TOKEN_VALUE=
STEWARD_PROXMOX_PASSWORD=
STEWARD_PROXMOX_VERIFY_SSL=true

# ---- Collector ----
STEWARD_POLL_INTERVAL_S=10
STEWARD_RING_BUFFER_SIZE=360

# ---- Demo ----
# When true (mock only), scripts periodic incidents for screenshots/gifs.
STEWARD_DEMO_MODE=false

# ---- Probes ----
# The shell_command probe is a foot-gun; opt in explicitly to allow it.
STEWARD_ALLOW_SHELL_PROBES=false

# ---- Metrics retention ----
# Raw metric rows older than this are pruned each cycle.
STEWARD_METRICS_RETENTION_HOURS=72

# ---- Action guardrails ----
# Master safety switch. When true, NO mutating action ever calls the client.
STEWARD_DRY_RUN=true
# When true, the executor is paused entirely (global kill switch).
STEWARD_PAUSED=false
# Comma-separated VMIDs eligible for AUTO actions. Empty = nothing auto-acts.
STEWARD_ACTION_ALLOWLIST=
# Per-action-type cooldown and hourly ceiling.
STEWARD_ACTION_COOLDOWN_S=300
STEWARD_ACTION_MAX_PER_HOUR=10

# ---- Autonomous balancer (Tier 0) ----
# The on/off switch is the `builtin.autonomous_balancer` CHECK (disabled by
# default; enable it in the UI/API). These only tune HOW it balances. Even when
# enabled, a guest auto-moves only if it is allow-listed AND dry-run is off.
STEWARD_BALANCER_WEIGHT_CPU=0.5
STEWARD_BALANCER_WEIGHT_MEM=0.5
# Never migrate onto a node that would exceed this CPU% or mem% afterwards.
STEWARD_BALANCER_MAX_TARGET_PCT=80
# Minimum blended-imbalance drop (stddev points) to bother moving a guest.
STEWARD_BALANCER_MIN_IMPROVEMENT=2
# Moves initiated per poll, and whether to require a rising/sustained trend.
STEWARD_BALANCER_MAX_MOVES_PER_CYCLE=1
STEWARD_BALANCER_REQUIRE_TREND=true
# Wait this long for a just-initiated migration to settle before the next.
STEWARD_BALANCER_MIGRATION_SETTLE_S=120

# ---- LLM (any OpenAI-compatible endpoint; Ollama works out of the box) ----
# Leave base_url blank to disable the LLM entirely (app still fully works).
STEWARD_LLM_BASE_URL=http://localhost:11434/v1
STEWARD_LLM_MODEL=llama3.2:3b
# Most local servers ignore the key; use a dummy. Real OpenAI needs a real key.
STEWARD_LLM_API_KEY=ollama
STEWARD_LLM_TIMEOUT_S=60

# ---- Notifications (pluggable; "none" disables) ----
# Options: none, ntfy, webhook
STEWARD_NOTIFY_KIND=none
STEWARD_NOTIFY_NTFY_URL=https://ntfy.sh/your-topic-here
STEWARD_NOTIFY_WEBHOOK_URL=

# ---- Escalation to Claude Code (Tier 2) ----
# Off unless a webhook URL is set. When a check fires repeatedly on the same
# target and stays unresolved, Steward POSTs a rich incident payload here; wire
# that webhook to kick off a Claude Code run that investigates and *proposes*
# remediation into the approval queue (it never bypasses guardrails).
STEWARD_ESCALATION_WEBHOOK_URL=
STEWARD_ESCALATION_MIN_OCCURRENCES=3      # fires this many times...
STEWARD_ESCALATION_MIN_AGE_S=600          # ...over at least this long (10 min)...
STEWARD_ESCALATION_COOLDOWN_S=3600        # ...and don't re-page within an hour
STEWARD_ESCALATION_TTL_S=1800             # quiet this long => treat as resolved

# ---- UI auth ----
# Simple shared-token auth for the UI/API. Blank disables auth (dev only).
STEWARD_AUTH_TOKEN=
